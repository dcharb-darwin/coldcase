# Ports (durable rule — see knowledge/launchpad/port-allocation.md)
BACKEND_PORT=7787
MONGO_PORT=27022
FRONTEND_PORT=5178

# Backend (FastAPI — standalone)
MONGODB_URI=mongodb://127.0.0.1:27022
DATABASE_NAME=darwin_coldcase
IS_DEV_BYPASS_AUTH_ENABLED=true
ENVIRONMENT=development
DEBUG=true
SERVICE_NAME=coldcase
CORS_ORIGINS=http://localhost:3000,http://localhost:5178
UPLOAD_DIRECTORY=./uploads
ENABLE_CLOUD_STORAGE=false

# Providers (mock = synthetic data, no external deps)
PROVIDER_EMPLOYEE=mock
PROVIDER_EMAIL=mock
PROVIDER_CALENDAR=mock
PROVIDER_TRAINING=mock
PROVIDER_EVALUATION=mock
PROVIDER_PHOTOS=mock

# LLM provider for the case-chat surface. Options:
#   mock     — local Ollama (default — see OLLAMA_BASE_URL / COLDCASE_LLM_MODEL)
#   openai   — OpenAI chat completions (set OPENAI_API_KEY and OPENAI_MODEL)
#   gcc_copilot — Microsoft 365 Copilot in agency GCC tenant (NOT YET WIRED)
PROVIDER_LLM=mock

# Ollama (mock provider)
OLLAMA_BASE_URL=http://localhost:11434
COLDCASE_LLM_MODEL=qwen3.6:35b-a3b-nvfp4
ADMIN_ASSISTANT_MODEL=qwen3.6:35b-a3b-nvfp4

# OpenAI (PROVIDER_LLM=openai)
# The exact model id OpenAI returns is captured on every assistant message and
# surfaces on the §13663(a)(1) disclosure footer.
OPENAI_API_KEY=
# Use the alias (e.g. `gpt-5.5`) so we always track the latest snapshot; the
# specific snapshot id (e.g. `gpt-5.5-2026-04-23`) is what OpenAI returns and
# what lands on the §13663(a)(1) disclosure footer.
OPENAI_MODEL=gpt-5.5

# Multimodal data-residency mode (PRD business rule #17). When `true`, the
# server streams PDF bytes inline to the LLM at request time and does NOT
# extract / cache text locally. The LLM reads the file natively (works for
# image-only scans too — no tesseract needed). Citations switch from the
# `[src: file, L<n>]` line-anchored form to `[src: file, p<page>, "quote"]`.
# Default off so the synthetic dev case keeps working without an OpenAI key.
COLDCASE_LLM_MULTIMODAL=false
# OPENAI_BASE_URL=https://api.openai.com/v1

# Production only (leave empty for local POC)
# DARWIN_IDENTITY_INTERNAL_TOKEN=
# DARWIN_IDENTITY_ENDPOINT=
# SESSION_SECRET_KEY=

# ── Agency letterhead (A) ──────────────────────────────────────────────────
# Stamped on every page of the signed report, chain-of-custody, diff, and
# case-audit-manifest PDFs. Leaving NAME blank disables the letterhead.
COLDCASE_AGENCY_NAME=
COLDCASE_AGENCY_JURISDICTION=
COLDCASE_AGENCY_ORI=
COLDCASE_AGENCY_ADDRESS=
COLDCASE_AGENCY_PHONE=
COLDCASE_AGENCY_LOGO_PATH=
