{
  "name": "coldcase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "api": "set -a; [ -f .env ] && . ./.env; set +a; cd server-py && PYTHONPATH=. ../.venv/bin/uvicorn server:app --host 0.0.0.0 --port ${BACKEND_PORT:-7787} --reload",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit",
    "preview": "vite preview",
    "dev:mongo": "docker compose up mongo -d",
    "dev:backend": "cd server-py && ../.venv/bin/python __main__.py"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "axios": "^1.7.0",
    "@tanstack/react-query": "^5.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^7.0.0"
  }
}
